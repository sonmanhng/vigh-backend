datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("ChuyenVien") // SuperAdmin, VienTruong, VienPho, TruongPhong, ChuyenVien (also legacy ADMIN, MANAGER, USER)
  avatar       String?
  department   String?
  phone        String?
  affiliations String[]  @default([])
  projects       Project[] @relation("ManagerProjects")
  memberProjects Project[] @relation("ProjectMembers")
  tasks          Task[]    @relation("AssigneeTasks")
  orcid          String?
  scholar        String?
  bio            String?
  researchInterests String[] @default([])
  chemicalProposals ChemicalProposal[] @relation("CreatorProposals")
  approved1Proposals ChemicalProposal[] @relation("Approver1Proposals")
  approved2Proposals ChemicalProposal[] @relation("Approver2Proposals")
  machineLogs      MachineLog[] @relation("MachineLogCreator")
  createdAt        DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Project {
  id               Int       @id @default(autoincrement())
  name             String
  nameEn           String?
  code             String?
  projectType      String?
  managementUnit   String?
  hostOrganization String?
  advisor          String?
  executionTime    String?
  budget           String?
  laborBudget      Float?    @default(0)
  generalObjective String?
  description      String?
  status           String    @default("PLANNING") // PLANNING, IN_PROGRESS, COMPLETED, ON_HOLD
  startDate        DateTime?
  endDate          DateTime?
  managerId        Int?
  manager          User?     @relation("ManagerProjects", fields: [managerId], references: [id])
  members          User[]    @relation("ProjectMembers")
  tasks            Task[]
  researchContents ResearchContent[]
  chemicalProposalItems ChemicalProposalItem[]
  machineLogs      MachineLog[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  progress    Int      @default(0) // 0 - 100
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  Int?
  assignee    User?    @relation("AssigneeTasks", fields: [assigneeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ResearchContent {
  id          Int      @id @default(autoincrement())
  code        String   // VD: ND1, ND2, ND3
  title       String   // VD: Điều tra dân tộc học...
  status      String   @default("Xong 100%") // VD: Xong 100%, Đang thực hiện
  description String?  // VD: Thu thập tri thức bản địa...
  activities  String?  // JSON string: '[{"activity":"...","result":"..."}]'
  projectId   Int
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chemical {
  id             Int                   @id @default(autoincrement())
  code           String                @unique   // Mã HC (VD: HC-001)
  name           String                // Tên hoá chất
  unit           String                // Đơn vị (Lít, Kg, Chai...)
  quantity       Float                 // Số lượng tồn kho hiện tại
  maxQuantity    Float                 // Định mức tối đa (để tính %)
  specification  Float                 // Quy cách (VD: 10 Lít)
  invoicePrice   Float                 // Giá hoá đơn (tổng tiền)
  unitPrice      Float                 // Đơn giá = invoicePrice / specification
  importDate     DateTime              // Ngày nhập kho
  alertThreshold Float     @default(50) // Ngưỡng cảnh báo (%)
  location       String?
  note           String?
  transactions   ChemicalTransaction[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ChemicalTransaction {
  id          Int      @id @default(autoincrement())
  type        String   // IMPORT | EXPORT
  chemicalId  Int
  chemical    Chemical @relation(fields: [chemicalId], references: [id], onDelete: Cascade)
  projectCode String?  // Mã dự án (khi xuất)
  quantity    Float    // Số lượng nhập/xuất
  note        String?
  createdById Int?
  createdAt   DateTime @default(now())
}

model ChemicalProposal {
  id           Int      @id @default(autoincrement())
  status       String   @default("PENDING") // PENDING, PENDING_LEVEL_2, APPROVED, REJECTED
  createdById  Int?
  creator      User?    @relation("CreatorProposals", fields: [createdById], references: [id], onDelete: SetNull)
  approver1Id  Int?
  approver1    User?    @relation("Approver1Proposals", fields: [approver1Id], references: [id], onDelete: SetNull)
  approver2Id  Int?
  approver2    User?    @relation("Approver2Proposals", fields: [approver2Id], references: [id], onDelete: SetNull)
  level1Status String   @default("PENDING") // PENDING, APPROVED, REJECTED
  level2Status String   @default("PENDING") // PENDING, APPROVED, REJECTED
  note         String?
  items        ChemicalProposalItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChemicalProposalItem {
  id           Int      @id @default(autoincrement())
  proposalId   Int
  proposal     ChemicalProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  chemicalName String
  unit         String
  quantity     Float
  phase        String?  // Giai đoạn
  projectId    Int?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectCode  String?
}

model Machine {
  id             Int          @id @default(autoincrement())
  code           String       @unique // Mã tài sản
  name           String       // Tên tài sản
  category       String?      // Phân loại
  department     String       // Đơn vị sử dụng
  characteristics String?     // Đặc điểm
  status         String       @default("IN_USE") // IN_USE, NOT_IN_USE
  logs           MachineLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MachineLog {
  id          Int      @id @default(autoincrement())
  machineId   Int
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  date        DateTime // Ngày tiêu hao
  minutes     Int      // Số phút tiêu hao
  projectId   Int?     // Dự án sử dụng máy
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdById Int?
  creator     User?    @relation("MachineLogCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}
